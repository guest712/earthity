{
  "expo": {
    "name": "earthity",
    "slug": "earthity",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/E_Icon.png",
    "scheme": "earthity",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "jsEngine": "hermes",
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/E_Icon.png",
        "backgroundColor": "#071C1C"
      },
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.anonymous.earthity"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-secure-store",
      "expo-router",
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Earthity uses your location for the map and nearby quests."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": false
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "72ecaaf3-db5f-408b-b321-694332f382bb"
      }
    },
    "owner": "mare_tranquillitatis"
  }
}
